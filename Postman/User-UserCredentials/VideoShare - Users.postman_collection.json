          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "carts",
            "{{missingCartId}}",
            "total"
          ]
        },
        "description": "Negative test case. Use this request after you add exception handling for missing carts. If you currently throw a plain RuntimeException, this may return 500 instead of 404."
      },
      "response": []
    }
