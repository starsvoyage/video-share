    {
      "name": "1 POST register - success (stores userId)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "// capture returned id if response includes it",
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {}",
              "",
              "let id = json.id || (json.data && json.data.id);",
              "if (id) {",
              "  pm.environment.set('userId', id);",
              "} else {",
              "  console.warn('Could not auto-detect id in response. Update this test if needed.');",
              "}",
              "",
              "// save username and email",
              "pm.environment.set('username', 'ian_postman_1');",
              "pm.environment.set('email', 'ian_postman_1@arizona.edu');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
