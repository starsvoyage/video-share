  },
  "item": [
    {
      "name": "Get Cart Total",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Response is JSON', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const body = pm.response.json();",
              "",
              "pm.test('cartId is present', function () {",
              "    pm.expect(body).to.have.property('cartId');",
              "});",
              "",
              "pm.test('totalCost is present', function () {",
              "    pm.expect(body).to.have.property('totalCost');",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/carts/{{cartId}}/total",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "carts",
            "{{cartId}}",
            "total"
          ]
        },
        "description": "Calculates the total cost of the shopping cart by summing quantity × product price for each cart item."
      },
      "response": []
    },
    {
      "name": "Get Cart Total - Missing Cart",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is an error status', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([404, 500]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
